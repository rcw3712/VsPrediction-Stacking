# ───────────────────────────────────────────────────────────
# .gitignore for VsPrediction-Stacking (MATLAB project)
# ───────────────────────────────────────────────────────────

# ===== MATLAB =====
*.mex
*.mexa64
*.mexmaci64
*.mexmaci
*.mexw64
*.mexw32

# Simulink autosave & cache
*.autosave
*.slxc
slprj/
sccprj/

# MATLAB session files
*.asv
*.m~

# Code analyzer reports
*.mlx.report

# MATLAB temp files
matlab_crash_dump.*

# ===== Project-specific =====

# Pipeline output (regenerated by main_pipeline)
results/*
!results/.gitkeep

# Raw confidential well-log data — NEVER COMMIT
# (Templates and documentation are explicitly re-included below)
data/*.csv
data/*.xlsx
data/*.xls
data/*.las
data/*.LAS
data/*.txt

# Explicit exceptions (commit these files even though above rules would ignore them)
!data/BT-4_template.csv
!data/BTS-1_template.csv
!data/README.md
!data/generate_synthetic_wells.m

# Local config overrides
config/my_*.m
config/local_*.m
config/*_local.m

# Logs and run artifacts
logs/
*.log
*.tmp

# Cached SHAP / feature importance computations
.shap_cache/
.feature_cache/

# ===== Editor / IDE =====
.vscode/
*.code-workspace
.idea/
*.iml

# Vim
*~
*.swp
*.swo
*.swn

# Sublime Text
*.sublime-project
*.sublime-workspace

# ===== Operating System =====
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

# ===== Python (helper scripts, if any) =====
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
env/

# ===== Misc =====
*.zip
*.tar
*.tar.gz
*.7z

# Trained model weights — keep only released versions
*.mat.bak
*.h5
*.onnx
checkpoints/
